{
    "name": "quarter_tg/telegram-bot",
    "description": "Group management bot for Telegram with advanced lock features including hashtag lock",
    "type": "project",
    "keywords": ["telegram", "bot", "group", "management", "lock", "hashtag"],
    "homepage": "https://github.com/parhampa/quarter_tg",
    "license": "MIT",
    "authors": [
        {
            "name": "Parham Pourmohammad",
            "email": "parhampa@example.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/parhampa/quarter_tg/issues",
        "source": "https://github.com/parhampa/quarter_tg"
    },
    "require": {
        "php": ">=7.4.0",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-mysqli": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.6",
        "phpstan/phpstan": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "QuarterTg\\Core\\": "src/Core/",
            "QuarterTg\\Helpers\\": "src/Helpers/",
            "Modules\\": "src/Modules/",
            "QuarterTg\\Exceptions\\": "src/Exceptions/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "test-coverage": "phpunit --configuration phpunit.xml --coverage-html coverage",
        "phpcs": "phpcs --standard=PSR12 src/",
        "phpcbf": "phpcbf --standard=PSR12 src/",
        "phpstan": "phpstan analyse src/ --level=5",
        "check": [
            "@phpcs",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "preferred-install": "dist",
        "platform": {
            "php": "7.4.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}