# ============================================================
# تنظیمات ضروری (اجباری)
# ============================================================
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
DB_PASSWORD=your_strong_db_password
OWNER_ID=123456789

# ============================================================
# تنظیمات دیتابیس (پیش‌فرض‌ها در config/config.php آمده است)
# ============================================================
DB_HOST=localhost
DB_NAME=quarter_tg
DB_USERNAME=root
DB_CHARSET=utf8mb4

# ============================================================
# تنظیمات کش و لاگ
# ============================================================
CACHE_PATH=./cache
CACHE_TTL=3600
LOG_PATH=./logs/app.log
LOG_LEVEL=info
LOG_MAX_SIZE=10485760

# ============================================================
# تنظیمات ماژول‌ها
# ============================================================
MODULES_PATH=./src/Modules
MODULES_NAMESPACE=QuarterTg\\Modules\\

# ============================================================
# تنظیمات امنیتی Webhook
# ============================================================
WEBHOOK_SECRET=your_webhook_secret
ALLOWED_IPS=149.154.160.0/20,91.108.4.0/22,93.190.128.0/18

# ============================================================
# تنظیمات منطقه زمانی و زبان
# ============================================================
TIMEZONE=Asia/Tehran
LOCALE=fa
APP_ENV=production

# ============================================================
# تنظیمات پروکسی (در صورت نیاز)
# ============================================================
# PROXY_HOST=proxy.example.com
# PROXY_PORT=8080
# PROXY_USERNAME=
# PROXY_PASSWORD=